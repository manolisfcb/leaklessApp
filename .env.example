# ---------------------------------------------------------------------------
# leakless — environment variables
#
# Copy this file to `.env` and fill in the real values:
#     cp .env.example .env
#
# `.env` is git-ignored and bundled as a Flutter asset (see pubspec.yaml).
# NEVER commit real keys.
# ---------------------------------------------------------------------------

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# RevenueCat — Project → API Keys (public SDK keys, one per platform)
REVENUECAT_PUBLIC_KEY_IOS=appl_your_ios_public_key
REVENUECAT_PUBLIC_KEY_ANDROID=goog_your_android_public_key

# Gemini (Google AI Studio) — powers receipt photo OCR in Quick Entry.
# Get a key at https://aistudio.google.com/app/apikey. Optional: when empty,
# the "Escanear recibo" button is simply hidden and manual entry still works.
# NOTE: this is a client-side key for now ("por ahora"). Before production,
# move the call behind a Supabase Edge Function so the key never ships in the
# app binary (see docs/PLAID_INTEGRATION.md for the proxy pattern).
GEMINI_API_KEY=your-google-ai-studio-key

# Optional: environment label shown in dev tooling (dev | staging | prod)
APP_ENV=dev
