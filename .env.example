# ---------------------------------------------------------------------------
# leakless — environment variables
#
# Copy this file to `.env` and fill in the real values:
#     cp .env.example .env
#
# `.env` is git-ignored and bundled as a Flutter asset (see pubspec.yaml).
# NEVER commit real keys.
# ---------------------------------------------------------------------------

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# RevenueCat — Project → API Keys (public SDK keys, one per platform)
REVENUECAT_PUBLIC_KEY_IOS=appl_your_ios_public_key
REVENUECAT_PUBLIC_KEY_ANDROID=goog_your_android_public_key

# Receipt photo OCR (Quick Entry). Off by default → manual entry only.
# The Gemini key is NEVER stored here or in the app; it lives as a server-side
# secret on the `scan-receipt` Supabase Edge Function. To turn scanning on:
#   1. supabase functions deploy scan-receipt
#   2. supabase secrets set GEMINI_API_KEY=<google-ai-studio-key>
#   3. set the flag below to true
# See docs/RECEIPT_OCR.md for the full setup.
RECEIPT_SCAN_ENABLED=false

# Optional: environment label shown in dev tooling (dev | staging | prod)
APP_ENV=dev
